# DynDNS-Hostname (z.B. myfriend.example.com)
DDNS_HOST=your-dyndns-hostname-here

# Exakter Name der Access-List in NPM (wie in der GUI angezeigt)
ACCESS_LIST_NAME=Your-Access-List-Name

# Prüfintervall in Sekunden (Standard: 300 = 5 Minuten)
CHECK_INTERVAL_SECONDS=300

# Name des NPM-Containers (wie im eigenen docker-compose von NPM konfiguriert)
NPM_CONTAINER_NAME=npm

# Hostpfad zum NPM-"data"-Verzeichnis
# Standard: ./data relativ zum docker-compose-Verzeichnis
NPM_DATA_PATH=./data

# Docker-Socket auf dem Host
DOCKER_SOCK_PATH=/var/run/docker.sock
